PORT=5000
NODE_ENV=production

# Frontend URL(s) allowed by CORS.
# You can provide one URL or comma-separated URLs.
# Example: https://filenest.vercel.app,https://filenest-staging.vercel.app
CORS_ORIGIN=https://your-frontend-domain
FRONTEND_URL=https://your-frontend-domain

# Security
JWT_SECRET=replace_with_a_long_random_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Database (supports either MYSQL* or DB_* names)
MYSQLHOST=your_mysql_host
MYSQLPORT=3306
MYSQLUSER=your_mysql_user
MYSQLPASSWORD=your_mysql_password
MYSQLDATABASE=your_mysql_database

# Alternative naming (optional)
# DB_HOST=your_mysql_host
# DB_PORT=3306
# DB_USER=your_mysql_user
# DB_PASSWORD=your_mysql_password
# DB_NAME=your_mysql_database
