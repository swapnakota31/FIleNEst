# Frontend environment (Vercel/Netlify)
# Use your deployed backend URL. You can set either:
# - full API URL (recommended), e.g. https://filenest-api.onrender.com/api
# - backend origin, e.g. https://filenest-api.onrender.com (the app auto-appends /api)
VITE_API_BASE_URL=https://your-backend-domain/api
